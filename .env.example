# Copy to .env and fill in. Rotate keys if they were ever committed or shared.
#
# Docker + Colima (Mac): colima start  →  make up  (see Makefile)
# compose sets REDIS_HOST=redis; keep REDIS_HOST=localhost below for optional native runs.
#
# Telegram: @BotFather -> /newbot or /token
BOT_TOKEN=

# Optional — only if you use AI summary features (see services/ai_olx.py)
OPENAI_API_KEY=

# Docker Compose (defaults match docker-compose service name)
REDIS_HOST=redis
REDIS_PORT=6379
